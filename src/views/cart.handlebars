<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h1 class="fw-bold text-light">Carrito</h1>
            <p class="text-secondary mb-0">Productos agregados</p>
        </div>

        <a href="/" class="btn btn-premium px-4">
            ← Volver a la tienda
        </a>
    </div>

    <div class="row g-4">
        {{#each cartProducts}}
            <div id="productCard{{this.product._id}}" class="col-12">
                <div class="product-card d-flex align-items-center p-3">
                    <img src="{{this.product.thumbnail}}" class="cart-product-img me-4">
                    <div class="ms-4 flex-grow-1">
                        <h5 class="text-light mb-1">{{this.product.title}}</h5>
                        <p class="text-secondary small mb-1">{{this.product.category}}</p>
                        <p class="text-muted small mb-0">{{this.product.description}}</p>
                    </div>

                    <div class="text-end me-4">
                        <div class="text-secondary small">Precio</div>
                        <div class="price">$ {{this.product.price}}</div>
                    </div>

                    <div class="text-center me-4">
                        <div class="text-secondary small">Cantidad</div>
                        <div class="text-light fw-semibold">
                            {{this.quantity}}
                        </div>
                    </div>

                    <div class="text-end me-4">
                        <div class="text-secondary small">Subtotal</div>
                        <div class="price-subtotal" data-subtotal="{{multiply this.product.price this.quantity}}">$ {{multiply this.product.price this.quantity}}</div>
                    </div>

                    <button id="delete{{this.product._id}}" class="btn btn-danger removeFromCart" data-id="{{this.product._id}}">✕</button>
                </div>
            </div>
        {{/each}}
    </div>

    <div class="mt-5 p-4 product-card d-flex justify-content-between align-items-center">
        <div><h4 class="text-light mb-0">Total del carrito</h4></div>
        <div id="total" class="price fs-4"></div>
    </div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
<script id="cartData" type="application/json">{{{json this}}}</script>
<script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<script src="/static/js/cart.js"></script>